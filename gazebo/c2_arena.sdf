          <geometry><box><size>0.330 0.036 0.020</size></box></geometry>
          <material><ambient>0.18 0.20 0.18 1</ambient><diffuse>0.18 0.20 0.18 1</diffuse>
            <specular>0.38 0.42 0.38 1</specular></material>
        </visual>
        <visual name="arm_b">
          <pose>0 0 -0.005 0 0 -0.785398</pose>
          <geometry><box><size>0.330 0.036 0.020</size></box></geometry>
          <material><ambient>0.18 0.20 0.18 1</ambient><diffuse>0.18 0.20 0.18 1</diffuse>
            <specular>0.38 0.42 0.38 1</specular></material>
        </visual>

        <visual name="hub_disc">
          <pose>0 0 0 0 0 0</pose>
          <geometry><cylinder><radius>0.075</radius><length>0.040</length></cylinder></geometry>
          <material><ambient>0.16 0.20 0.16 1</ambient><diffuse>0.16 0.20 0.16 1</diffuse>
            <specular>0.45 0.52 0.45 1</specular></material>
        </visual>
        <!-- Agent colour accent ring (green for drone2) -->
        <visual name="hub_ring">
          <pose>0 0 0.022 0 0 0</pose>
          <geometry><cylinder><radius>0.068</radius><length>0.005</length></cylinder></geometry>
          <material><ambient>0.15 0.80 0.50 1</ambient><diffuse>0.15 0.80 0.50 1</diffuse>
            <specular>0.30 0.90 0.60 1</specular></material>
        </visual>

        <visual name="battery">
          <pose>0 0 0.038 0 0 0</pose>
          <geometry><box><size>0.140 0.044 0.030</size></box></geometry>
          <material><ambient>0.10 0.14 0.10 1</ambient><diffuse>0.10 0.14 0.10 1</diffuse></material>
        </visual>

        <visual name="motor_fr"><pose> 0.117 -0.117 0.014 0 0 0</pose>
          <geometry><cylinder><radius>0.024</radius><length>0.034</length></cylinder></geometry>
          <material><ambient>0.12 0.16 0.12 1</ambient><diffuse>0.12 0.16 0.12 1</diffuse>
            <specular>0.55 0.65 0.55 1</specular></material>
        </visual>
        <visual name="motor_fl"><pose> 0.117  0.117 0.014 0 0 0</pose>
          <geometry><cylinder><radius>0.024</radius><length>0.034</length></cylinder></geometry>
          <material><ambient>0.12 0.16 0.12 1</ambient><diffuse>0.12 0.16 0.12 1</diffuse>
            <specular>0.55 0.65 0.55 1</specular></material>
        </visual>
        <visual name="motor_br"><pose>-0.117 -0.117 0.014 0 0 0</pose>
          <geometry><cylinder><radius>0.024</radius><length>0.034</length></cylinder></geometry>
          <material><ambient>0.12 0.16 0.12 1</ambient><diffuse>0.12 0.16 0.12 1</diffuse>
            <specular>0.55 0.65 0.55 1</specular></material>
