{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "GeoCloud Fleet — End-to-end topic latency and high-latency event tracking",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "title": "End-to-End Latency — All Robots (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max","lastNotNull"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (robot, le) (rate(ros2_topic_latency_seconds_bucket[1m]))) * 1000",
          "legendFormat": "{{robot}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (robot, le) (rate(ros2_topic_latency_seconds_bucket[1m]))) * 1000",
          "legendFormat": "{{robot}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (robot, le) (rate(ros2_topic_latency_seconds_bucket[1m]))) * 1000",
          "legendFormat": "{{robot}} p99",
          "refId": "C"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 100 },
          { "color": "red", "value": 300 }
        ]
      }
    },

    {
      "id": 2,
      "title": "High-Latency Events / sec — by Robot",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      },
      "targets": [
        {
          "expr": "rate(ros2_topic_high_latency_total[1m])",
          "legendFormat": "{{robot}} {{topic}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "Current p95 Latency — per Robot",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 300 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (robot, le) (rate(ros2_topic_latency_seconds_bucket[1m]))) * 1000",
          "legendFormat": "{{robot}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "Latency Heatmap — /camera/compressed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (topic, le) (rate(ros2_topic_latency_seconds_bucket{topic=~\".*/camera/compressed\"}[1m]))) * 1000",
          "legendFormat": "{{topic}} p99",
          "refId": "A"
        }
      ]
    }

  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["geoclouds", "fleet", "latency", "ros2"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": true,
        "label": "Robot",
        "multi": true,
        "name": "robot",
        "options": [],
        "query": {
          "query": "label_values(ros2_topic_latency_seconds_count, robot)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "GeoCloud Fleet — Latency Dashboard",
  "uid": "geoclouds-fleet-latency-v1",
  "version": 1
}
